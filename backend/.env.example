# ── App ─────────────────────────────────────────────────────────────
APP_NAME="PropertyValuation API"
APP_VERSION="1.0.0"
DEBUG=true
API_PREFIX="/api/v1"

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://propval:propval@localhost:5432/propval"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Security ─────────────────────────────────────────────────────────
SECRET_KEY="CHANGE_ME_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Development: skip external APIs, use seed data ───────────────────
# Set to true to use MockPropertyDataService (no Land Registry / EPC calls)
MOCK_EXTERNAL_APIS=true

# ── External APIs (only needed when MOCK_EXTERNAL_APIS=false) ────────
LAND_REGISTRY_BASE_URL="https://use-land-property-data.service.gov.uk/api/v1"
EPC_API_BASE_URL="https://epc.opendatacommunities.org/api/v1"
EPC_API_KEY=""
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
GEOCODE_USER_AGENT="PropertyValuationMVP/1.0 contact@yourdomain.com"

# ── Valuation ────────────────────────────────────────────────────────
VALUATION_CACHE_DAYS=30
COMPARABLE_RADIUS_M=1000
COMPARABLE_MAX_AGE_YEARS=3
COMPARABLE_MIN_COUNT=3

# ── PDF ──────────────────────────────────────────────────────────────
REPORTS_DIR="/tmp/reports"
